# ============================================================
# mosgarage/code-server — standalone / WSL dev environment
# cp .env.example .env  then edit before running
# ============================================================

# ── code-server ────────────────────────────────────────────────────
CODE_SERVER_PASSWORD=Password123.
# CS_DISABLE_AUTH=true          # uncomment for trusted local-only mode

# ── SSH keys ───────────────────────────────────────────────────────
# Pull SSH public keys from GitHub automatically on startup
GITHUB_USER=mosgaragedev

# ── Git identity ───────────────────────────────────────────────────
GIT_NAME=mosgaragedev
GIT_EMAIL=mosgaragedev@users.noreply.github.com
GITHUB_TOKEN=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                   # ghp_... or leave blank if using SSH key

# ── Variant label (informational) ──────────────────────────────────
MOSGARAGE_VARIANT=base          # base | sdk | python | full

# ── Control plane connection (when running standalone) ─────────────
# MOSGARAGE_ACCESS_URL=http://localhost:7070
# MOSGARAGE_AGENT_PORT=7072
